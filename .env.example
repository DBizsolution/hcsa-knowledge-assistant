# ── OpenAI ────────────────────────────────────────────────────────────────
# Used for chat generation (gpt-4o) and embeddings (text-embedding-3-small).
OPENAI_API_KEY=sk-...
# Optional: override the chat model (defaults to gpt-4o)
# OPENAI_CHAT_MODEL=gpt-4o

# ── Supabase ──────────────────────────────────────────────────────────────
# Project URL + anon key (browser/auth) and service-role key (ingestion/server).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
SUPABASE_SERVICE_ROLE_KEY=ey...

# ── Ingestion (optional) ────────────────────────────────────────────────────
# Absolute path to the mock corpus. Defaults to the repo-root extracted dataset.
# CORPUS_DIR=/Users/rahul/DBiz/singapore/extracted/Mock Dataset for AI-Driven LLM Prototype
